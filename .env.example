REACT_APP_SHEET_ID=your_google_spreadsheet_id_here
REACT_APP_SHEET_NAME=Sheet1
# Browser API key — lists all tabs when you add new sheets in Google Sheets:
REACT_APP_GOOGLE_API_KEY=your_browser_api_key_here
REACT_APP_REFRESH_MS=5000

# Optional fallback only if auto-detect fails (comma-separated tab names):
# REACT_APP_SHEET_NAMES=Sheet1,Sheet2
